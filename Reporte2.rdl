  <DataSources>
    <DataSource Name="COMPUBLANCA">
      <rd:SecurityType>Integrated</rd:SecurityType>
      <ConnectionProperties>
        <DataProvider>SQL</DataProvider>
        <ConnectString>Data Source=COMPU-BLANCA;Initial Catalog=SistemaNomina2</ConnectString>
        <IntegratedSecurity>true</IntegratedSecurity>
      </ConnectionProperties>
      <rd:DataSourceID>75bd1f5a-9803-411c-baa0-9f8c8506fa23</rd:DataSourceID>
    </DataSource>
  </DataSources>
  <DataSets>
    <DataSet Name="DataSet1">
      <Query>
        <DataSourceName>COMPUBLANCA</DataSourceName>
        <rd:UseGenericDesigner>true</rd:UseGenericDesigner>
        <CommandText>SELECT estado_civil,
       COUNT(*) AS total_empleados
FROM   RRHH.Empleado
WHERE  is_active = 1
GROUP BY estado_civil
ORDER BY total_empleados DESC;</CommandText>
      </Query>
      <Fields>
        <Field Name="estado_civil">
          <rd:TypeName>System.String</rd:TypeName>
          <DataField>estado_civil</DataField>
        </Field>
        <Field Name="total_empleados">
          <rd:TypeName>System.Int32</rd:TypeName>
          <DataField>total_empleados</DataField>
        </Field>
      </Fields>
    </DataSet>
  </DataSets>
