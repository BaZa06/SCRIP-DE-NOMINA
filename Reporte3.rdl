  <DataSets>
    <DataSet Name="SistemaNomina2">
      <Query>
        <DataSourceName>COMPUBLANCA</DataSourceName>
        <CommandText>SELECT nombre_cargo, salario_base,
       salario_extraordinario
FROM   RRHH.Cargo
WHERE  salario_base &gt; 30000
  AND  is_active = 1
ORDER BY salario_base DESC;</CommandText>
      </Query>
      <Fields>
        <Field Name="nombre_cargo">
          <rd:TypeName>System.String</rd:TypeName>
          <DataField>nombre_cargo</DataField>
        </Field>
        <Field Name="salario_base">
          <rd:TypeName>System.Decimal</rd:TypeName>
          <DataField>salario_base</DataField>
        </Field>
        <Field Name="salario_extraordinario">
          <rd:TypeName>System.Decimal</rd:TypeName>
          <DataField>salario_extraordinario</DataField>
        </Field>
      </Fields>
    </DataSet>
  </DataSets>
