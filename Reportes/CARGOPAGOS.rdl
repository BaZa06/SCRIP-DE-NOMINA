  <DataSources>
    <DataSource Name="OrigenNomina">
      <rd:SecurityType>Integrated</rd:SecurityType>
      <ConnectionProperties>
        <DataProvider>SQL</DataProvider>
        <ConnectString>Data Source=DESKTOP-EC3V4MM;Initial Catalog=SistemaNomina3FN</ConnectString>
        <IntegratedSecurity>true</IntegratedSecurity>
      </ConnectionProperties>
      <rd:DataSourceID>af1c7f06-7a07-43d6-9a60-f9aa7374fb41</rd:DataSourceID>
    </DataSource>
  </DataSources>
  <DataSets>
    <DataSet Name="DatosInforme">
      <Query>
        <DataSourceName>OrigenNomina</DataSourceName>
        <CommandText>SELECT 
    e.numero_inss AS INSS,
    CONCAT(e.primer_nombre, ' ', e.primer_apellido) AS Empleado,
    c.nombre_cargo AS Cargo,
    n.total_percepciones AS IngresosBrutos,
    n.total_deducciones AS TotalDeducciones,
    n.salario_neto AS NetoRecibir
FROM NOMINA.Nomina n
INNER JOIN RRHH.Empleado e ON n.id_empleado = e.id_empleado
INNER JOIN RRHH.Cargo c ON n.id_cargo = c.id_cargo
INNER JOIN NOMINA.Periodo_Nomina pn ON n.id_periodo = pn.id_periodo
WHERE pn.is_active = 1
ORDER BY Empleado;</CommandText>
      </Query>
      <Fields>
        <Field Name="INSS">
          <rd:TypeName>System.String</rd:TypeName>
          <DataField>INSS</DataField>
        </Field>
        <Field Name="Empleado">
          <rd:TypeName>System.String</rd:TypeName>
          <DataField>Empleado</DataField>
        </Field>
        <Field Name="Cargo">
          <rd:TypeName>System.String</rd:TypeName>
          <DataField>Cargo</DataField>
        </Field>
        <Field Name="IngresosBrutos">
          <rd:TypeName>System.Decimal</rd:TypeName>
          <DataField>IngresosBrutos</DataField>
        </Field>
        <Field Name="TotalDeducciones">
          <rd:TypeName>System.Decimal</rd:TypeName>
          <DataField>TotalDeducciones</DataField>
        </Field>
        <Field Name="NetoRecibir">
          <rd:TypeName>System.Decimal</rd:TypeName>
          <DataField>NetoRecibir</DataField>
        </Field>
      </Fields>
    </DataSet>
    <DataSet Name="CostodeCargaporPuesto">
      <Query>
        <DataSourceName>OrigenNomina</DataSourceName>
        <CommandText>SELECT 
    c.nombre_cargo AS Cargo,
    COUNT(n.id_empleado) AS TotalEmpleados,
    SUM(n.total_percepciones) AS TotalSalarios,
    SUM(ISNULL(ap.monto, 0)) AS TotalCargaPatronal,
    (SUM(n.total_percepciones) + SUM(ISNULL(ap.monto, 0))) AS CostoTotalCargo
FROM NOMINA.Nomina n
INNER JOIN RRHH.Cargo c ON n.id_cargo = c.id_cargo
INNER JOIN NOMINA.Periodo_Nomina pn ON n.id_periodo = pn.id_periodo
LEFT JOIN FISCAL.Aporte_Patronal ap ON n.id_nomina = ap.id_nomina
WHERE pn.is_active = 1
GROUP BY c.nombre_cargo
ORDER BY CostoTotalCargo DESC;</CommandText>
      </Query>
      <Fields>
        <Field Name="Cargo">
          <rd:TypeName>System.String</rd:TypeName>
          <DataField>Cargo</DataField>
        </Field>
        <Field Name="TotalEmpleados">
          <rd:TypeName>System.Int32</rd:TypeName>
          <DataField>TotalEmpleados</DataField>
        </Field>
        <Field Name="TotalSalarios">
          <rd:TypeName>System.Decimal</rd:TypeName>
          <DataField>TotalSalarios</DataField>
        </Field>
        <Field Name="TotalCargaPatronal">
          <rd:TypeName>System.Decimal</rd:TypeName>
          <DataField>TotalCargaPatronal</DataField>
        </Field>
        <Field Name="CostoTotalCargo">
          <rd:TypeName>System.Decimal</rd:TypeName>
          <DataField>CostoTotalCargo</DataField>
        </Field>
      </Fields>
    </DataSet>
  </DataSets>
