  <DataSources>
    <DataSource Name="Nomina">
      <rd:SecurityType>Integrated</rd:SecurityType>
      <ConnectionProperties>
        <DataProvider>SQL</DataProvider>
        <ConnectString>Data Source=DESKTOP-EC3V4MM;Initial Catalog=SistemaNomina3FN</ConnectString>
        <IntegratedSecurity>true</IntegratedSecurity>
      </ConnectionProperties>
      <rd:DataSourceID>dfbaac90-55da-4c0d-a727-5661dcf9242c</rd:DataSourceID>
    </DataSource>
  </DataSources>
  <DataSets>
    <DataSet Name="Informe3">
      <Query>
        <DataSourceName>Nomina</DataSourceName>
        <CommandText>SELECT 
    YEAR(pn.fecha_inicio) AS Anio,
    MONTH(pn.fecha_inicio) AS NumMes,
    DATENAME(MONTH, pn.fecha_inicio) AS Mes,
    SUM(n.total_percepciones) AS BrutoGlobal,
    SUM(n.total_deducciones) AS DeduccionesGlobales,
    SUM(n.salario_neto) AS NetoGlobal
FROM NOMINA.Nomina n
INNER JOIN NOMINA.Periodo_Nomina pn ON n.id_periodo = pn.id_periodo
GROUP BY YEAR(pn.fecha_inicio), MONTH(pn.fecha_inicio), DATENAME(MONTH, pn.fecha_inicio)
ORDER BY Anio DESC, NumMes ASC;</CommandText>
      </Query>
      <Fields>
        <Field Name="Anio">
          <rd:TypeName>System.Int32</rd:TypeName>
          <DataField>Anio</DataField>
        </Field>
        <Field Name="NumMes">
          <rd:TypeName>System.Int32</rd:TypeName>
          <DataField>NumMes</DataField>
        </Field>
        <Field Name="Mes">
          <rd:TypeName>System.String</rd:TypeName>
          <DataField>Mes</DataField>
        </Field>
        <Field Name="BrutoGlobal">
          <rd:TypeName>System.Decimal</rd:TypeName>
          <DataField>BrutoGlobal</DataField>
        </Field>
        <Field Name="DeduccionesGlobales">
          <rd:TypeName>System.Decimal</rd:TypeName>
          <DataField>DeduccionesGlobales</DataField>
        </Field>
        <Field Name="NetoGlobal">
          <rd:TypeName>System.Decimal</rd:TypeName>
          <DataField>NetoGlobal</DataField>
        </Field>
      </Fields>
    </DataSet>
  </DataSets>
